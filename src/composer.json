{
  "name": "crossfit/ranking",
  "description": "Crossfit Personal Record Ranking API",
  "type": "project",
  "require": {
    "php": "^8.4"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --testdox",
    "test:unit": "phpunit --testdox --testsuite=Unit",
    "test:coverage": "phpunit --coverage-html coverage/"
  }
}
